# ---------------------------------------------------------------------------
# HTTP → HTTPS redirect
# ---------------------------------------------------------------------------
http:// {
  redir https://{host}{uri} permanent
}

adguard.am180.us {
  import tls_wildcard
  import lan_only
  reverse_proxy host.docker.internal:3000
}

# ---------------------------------------------------------------------------
# Stack landing page
# ---------------------------------------------------------------------------
stack.am180.us {
  import tls_wildcard
  import lan_only
  root * /www/stack
  file_server
}
