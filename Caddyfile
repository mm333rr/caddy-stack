# =============================================================================
# Caddyfile — am180.us reverse proxy
# Wildcard cert via Cloudflare DNS-01 challenge.
# CF_API_TOKEN_FILE injected via Docker secret → /run/secrets/cf_api_token
# =============================================================================

{
  email {$ACME_EMAIL}
  admin off

  log {
    output file /logs/caddy-global.log {
      roll_size 50MiB
      roll_keep 5
      roll_keep_for 720h
    }
    format json
    level INFO
  }
}

# ---------------------------------------------------------------------------
# Shared TLS snippet — wildcard *.am180.us via Cloudflare DNS-01
# ---------------------------------------------------------------------------
(tls_wildcard) {
  tls {
    dns cloudflare {file.{$CF_API_TOKEN_FILE}}
    resolvers 1.1.1.1
  }
}

# LAN-only access snippet
(lan_only) {
  @external not remote_ip 192.168.0.0/16 172.16.0.0/12 10.0.0.0/8 127.0.0.1/8
  respond @external "Forbidden" 403
}

# ---------------------------------------------------------------------------
# Observability
# ---------------------------------------------------------------------------

grafana.am180.us {
  import tls_wildcard
  reverse_proxy grafana:3000
}

prometheus.am180.us {
  import tls_wildcard
  import lan_only
  reverse_proxy prometheus:9090
}

alertmanager.am180.us {
  import tls_wildcard
  import lan_only
  reverse_proxy alertmanager:9093
}

