# =============================================================================
# Caddyfile — am180.us reverse proxy
# Wildcard cert via Cloudflare DNS-01 challenge.
# CF_API_TOKEN_FILE injected via Docker secret → /run/secrets/cf_api_token
# Last updated: 2026-03-05 — added Tailscale CGNAT 100.64.0.0/10 to lan_only snippet
# =============================================================================

{
  email {$ACME_EMAIL}
  admin off

  log {
    output file /logs/caddy-global.log {
      roll_size 50MiB
      roll_keep 5
      roll_keep_for 720h
    }
    format json
    level INFO
  }
}

# ---------------------------------------------------------------------------
# Shared TLS snippet — wildcard *.am180.us via Cloudflare DNS-01
# ---------------------------------------------------------------------------
(tls_wildcard) {
  tls {
    dns cloudflare {file.{$CF_API_TOKEN_FILE}}
    resolvers 1.1.1.1
  }
}

# LAN + Tailscale access snippet
# Covers: LAN (192.168.x), Docker bridge (172.16-31.x), VPN (10.x), Tailscale CGNAT (100.64.x), localhost
(lan_only) {
  @external not remote_ip 192.168.0.0/16 172.16.0.0/12 10.0.0.0/8 100.64.0.0/10 127.0.0.1/8
  respond @external "Forbidden" 403
}

# ---------------------------------------------------------------------------
# Stack landing page — PUBLIC (no lan_only — just links, no sensitive data)
# iCloud Private Relay and WAN hairpin make lan_only incompatible with iOS
# ---------------------------------------------------------------------------
stack.am180.us {
  import tls_wildcard
  log {
    output file /logs/caddy-access-stack.log {
      roll_size 10MiB
      roll_keep 3
    }
    format json
    level DEBUG
  }
  root * /www/stack
  file_server
}

# ---------------------------------------------------------------------------
# Observability — Grafana public (has its own auth), others LAN-only
# ---------------------------------------------------------------------------
grafana.am180.us {
  import tls_wildcard
  reverse_proxy grafana:3000
}

prometheus.am180.us {
  import tls_wildcard
  import lan_only
  reverse_proxy prometheus:9090
}

alertmanager.am180.us {
  import tls_wildcard
  import lan_only
  reverse_proxy alertmanager:9093
}

